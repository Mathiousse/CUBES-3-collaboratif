{
    "name": "goodfood/logistique-api",
    "description": "Logistics API for Good Food MVP - Symfony + PostgreSQL",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.0",
        "symfony/runtime": "^7.0",
        "symfony/dotenv": "^7.0",
        "symfony/yaml": "^7.0",
        "symfony/console": "^7.0",
        "symfony/orm-pack": "^2.4",
        "symfony/maker-bundle": "^1.50",
        "doctrine/doctrine-bundle": "^2.11",
        "doctrine/orm": "^3.0",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "nelmio/cors-bundle": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ]
    }
}

